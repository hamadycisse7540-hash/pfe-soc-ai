<group name="syslog,sshd,">
  <rule id="100010" level="10" frequency="5" timeframe="300">
    <if_matched_sid>5758</if_matched_sid>
    <same_source_ip />
    <description>Attaque brute force SSH persistante détectée - Blocage recommandé</description>
    <mitre>
      <id>T1110.001</id>
      <tactic>Credential Access</tactic>
      <technique>Brute Force: Password Guessing</technique>
    </mitre>
    <group>authentication_failed,brute_force_attack,pci_dss_11.4,gdpr_IV_35.7.d,</group>
  </rule>
</group>