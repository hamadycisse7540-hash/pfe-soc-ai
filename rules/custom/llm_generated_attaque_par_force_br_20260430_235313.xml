<group name="local,syslog,sshd,">
  <rule id="100016" level="15" frequency="40" timeframe="300">
    <if_matched_sid>100015</if_matched_sid>
    <same_source_ip />
    <description>Attaque par force brute SSH prolongée et persistante sur root - CRITICAL</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failed,brute_force,pci_dss_10.2.4,pci_dss_10.2.5,gpg13_7.8,gdpr_IV_35.7.d,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,tsc_CC6.1,tsc_CC6.8</group>
  </rule>

  <rule id="100017" level="10">
    <if_sid>5716</if_sid>
    <match>user=root</match>
    <description>Tentative d'authentification SSH échouée sur compte root</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5</group>
  </rule>
</group>