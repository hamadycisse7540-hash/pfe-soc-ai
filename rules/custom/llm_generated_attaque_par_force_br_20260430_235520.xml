<group name="llm_generated,local,">
<rule id="100010" level="12">
  <if_sid>5551</if_sid>
  <match>user=root</match>
  <description>Attaque par force brute SSH détectée sur compte root - Blocage automatique recommandé</description>
  <mitre>
    <id>T1110.001</id>
    <tactic>Credential Access</tactic>
    <technique>Brute Force: Password Guessing</technique>
  </mitre>
  <group>authentication_failures,pam,brute_force_root</group>
  <options>no_email_alert</options>
</rule>

<rule id="100011" level="15">
  <if_sid>100010</if_sid>
  <same_source_ip />
  <description>CRITIQUE: Attaque par force brute persistante sur root depuis la même IP - Action de blocage requise</description>
  <mitre>
    <id>T1110.001</id>
    <tactic>Credential Access</tactic>
    <technique>Brute Force: Password Guessing</technique>
  </mitre>
  <group>authentication_failures,pam,brute_force_root,active_response</group>
</rule>
</group>